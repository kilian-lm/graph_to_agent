# Graph-to-Agent Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# Required: API Keys
# ===================

# OpenAI API key for LLM calls
OPENAI_API_KEY=sk-your-key-here

# ===================
# Optional: BigQuery
# ===================

# BigQuery service account credentials (JSON string)
# Only needed if using BigQuery for persistence
# BQ_CLIENT_SECRETS={"type":"service_account","project_id":"..."}

# ===================
# App Configuration
# ===================

# Accept EULA (set to TRUE to skip agreement page)
EULA_O_K=TRUE

# OpenAI model to use
MODEL=gpt-3.5-turbo

# OpenAI API endpoint (default is fine for most users)
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# ===================
# BigQuery Tables
# ===================

# Dataset IDs (only if using BigQuery)
GRAPH_DATASET_ID=graph_to_agent
ADJACENCY_MATRIX_DATASET_ID=graph_to_agent_adjacency_matrices
MULTI_LAYERED_MATRIX_DATASET_ID=graph_to_agent_multi_layered_metrices
CURATED_CHAT_COMPLETIONS=graph_to_agent_chat_completions
ANSWER_CURATED_CHAT_COMPLETIONS=graph_to_agent_answer_curated_chat_completions

# Table names
EDGES_TABLE=edges_table
NODES_TABLE=nodes_table

# ===================
# Miscellaneous
# ===================

# Number of steps for graph traversal
NUM_STEPS=10

# Local log directory
LOG_DIR_LOCAL=./temp_log
